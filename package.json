{
  "name": "codeagent",
  "version": "0.1.0",
  "description": "A Claude Code-like AI coding assistant CLI",
  "type": "module",
  "bin": {
    "codeagent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "node --import tsx/esm src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "diff": "^7.0.0",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^3.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
